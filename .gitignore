# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Raw media — never commit these (huge, unoptimized)
*.mov
*.mp4
*.webm
*.jpg
*.jpeg
*.png
*.tif
*.tiff
*.avif
*.webp

# …but DO commit optimized outputs that ship with the site
!public/**/*.jpg
!public/**/*.jpeg
!public/**/*.png
!public/**/*.webp
!public/**/*.avif
!public/**/*.mp4
!public/**/*.webm

# Raw originals stay local — only optimized variants get committed
public/assets/photos/_originals/
public/assets/video/_originals/

.vercel
.env*.local
